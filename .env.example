# Copy to .env (which is gitignored) and fill real values.

# ---- LLM ----
OPENAI_API_KEY=sk-...
MP_API_KEY=...

# ---- Database ----
# Local dev: install Postgres locally or run via docker-compose.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://tritondft:tritondft@localhost:5432/tritondft

# ---- Auth ----
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-long-random-string

# Comma-separated. These users are seeded as admin + unlimited credits on first start.
ADMIN_EMAILS=yil384@ucsd.edu,zhh068@ucsd.edu

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
EMAIL_FROM=TritonDFT <admin@picasso-lab.com>

# Where the magic link should land. Must serve a callback page that POSTs the token to /auth/verify.
FRONTEND_BASE_URL=https://yil384.github.io/TritonDFT-frontend
